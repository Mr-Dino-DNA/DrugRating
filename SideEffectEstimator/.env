# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=side_effect_estimator
DB_USER=michael
DB_PASSWORD=password

# Data File Paths (update these with your actual paths)
DRUGBANK_XML_PATH=/home/michael/SideEffectEstimator/DrugBank2023.xml
SIDER_MEDDRA_ALL_SE_PATH=/home/michael/SideEffectEstimator/meddra_all_se.tsv
SIDER_MEDDRA_FREQ_PATH=/home/michael/SideEffectEstimator/meddra_freq.tsv

# BindingDB (download from https://www.bindingdb.org/bind/downloads.jsp)
# Optional: Only needed if you want additional binding affinity data
BINDINGDB_TSV_PATH=/home/michael/SideEffectEstimator/BindingDB_All.tsv
ENABLE_BINDINGDB=true
# Enhanced Data Source Options
ENABLE_PUBCHEM_ENRICHMENT=true
ENABLE_CHEMBL=true
ENABLE_BINDINGDB=false

# API Rate Limiting
PUBCHEM_REQUESTS_PER_SECOND=5
PUBCHEM_MAX_RETRIES=3

# ChEMBL Configuration
MIN_BINDING_AFFINITY_CONFIDENCE=5

# Active Probability Data
ACTIVE_PROBABILITY_CSV_PATH=/home/michael/SideEffectEstimator/Active_Probability.csv

# OnSIDES Configuration (modern side effect database)
ONSIDES_CSV_DIR=/home/michael/SideEffectEstimator/OnSIDES/csv
ENABLE_ONSIDES=true
ONSIDES_MIN_CONFIDENCE=0.5

# Prediction Settings
SIMILARITY_THRESHOLD=0.7
MIN_PREDICTION_CONFIDENCE=0.5
MAX_SIMILAR_DRUGS=10

# Optional: Batch size for database inserts
BATCH_SIZE=1000

